{
  "name": "@pablozaiden/ralpher",
  "description": "Ralpher is a web and rest service used to control and manage Ralph Loops in opencode",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:server",
    "dev:server": "cd apps/server && bun run dev",
    "dev:cli": "cd apps/cli && bun run dev",
    "start": "bun run start:server",
    "start:server": "cd apps/server && bun run start",
    "build": "bun scripts/run-build.ts",
    "build:workspaces": "bun scripts/run-workspace-script.ts build",
    "test": "bun scripts/run-tests.ts all",
    "test:backend": "bun scripts/run-tests.ts backend",
    "test:frontend": "bun scripts/run-tests.ts frontend",
    "tsc": "mkdir -p .cache/tsc && bunx tsc --noEmit --pretty false --incremental --tsBuildInfoFile .cache/tsc/build.tsbuildinfo",
    "tsc:workspaces": "bun scripts/run-workspace-script.ts build"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@pablozaiden/installer": "0.0.6",
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.0",
    "@tailwindcss/typography": "0.5.19",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "bun-plugin-tailwind": "0.1.2",
    "highlight.js": "11.11.1",
    "jose": "6.2.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "tailwindcss": "4.3.0",
    "tslog": "4.10.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.9.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
