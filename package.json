{
  "name": "@pablozaiden/clanky",
  "description": "Clanky is a web and rest service used to control and manage Clanky Tasks in opencode",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build:novnc && bun --hot src/index.ts serve",
    "dev:server": "bun run dev",
    "start": "bun src/index.ts serve",
    "start:server": "bun run start",
    "build": "bun scripts/run-build.ts",
    "build:novnc": "bun scripts/novnc-vendor.ts",
    "test": "bun scripts/run-tests.ts all",
    "test:backend": "bun scripts/run-tests.ts backend",
    "test:frontend": "bun scripts/run-tests.ts frontend",
    "tsc": "mkdir -p .cache/tsc && bunx tsc --noEmit --pretty false --incremental --tsBuildInfoFile .cache/tsc/build.tsbuildinfo"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@monaco-editor/react": "4.7.0",
    "@novnc/novnc": "1.7.0",
    "@pablozaiden/installer": "0.0.6",
    "@pablozaiden/webapp": "1.2.0",
    "@tailwindcss/typography": "0.5.20",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "bun-plugin-tailwind": "0.1.2",
    "highlight.js": "11.11.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "reflect-metadata": "0.2.2",
    "remark-gfm": "4.0.1",
    "tailwindcss": "4.3.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.10.6",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "7.0.2"
  }
}
