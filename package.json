{
  "name": "@pablozaiden/ralpher",
  "description": "Ralpher is a web and rest service used to control and manage Ralph Loops in opencode",
  "version": "0.0.0-development",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun scripts/run-build.ts",
    "test": "bun scripts/run-tests.ts all",
    "test:backend": "bun scripts/run-tests.ts backend",
    "test:frontend": "bun scripts/run-tests.ts frontend",
    "tsc": "mkdir -p .cache/tsc && bunx tsc --noEmit --pretty false --incremental --tsBuildInfoFile .cache/tsc/build.tsbuildinfo"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.0",
    "@tailwindcss/typography": "0.5.19",
    "bun-plugin-tailwind": "0.1.2",
    "ghostty-web": "0.4.0",
    "jose": "6.2.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "tailwindcss": "4.1.18",
    "tslog": "4.10.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.9.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.10",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
