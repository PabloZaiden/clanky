{
  "schemaVersion": 1,
  "repo": "pablozaiden/clanky",
  "installDir": "$HOME/.local/bin",
  "binaries": [
    {
      "name": "clanky",
      "assetPrefix": "clanky",
      "postInstallMessage": "Run 'clanky serve' to start the local server, or 'clanky --help' for CLI commands."
    }
  ],
  "checksums": {
    "required": true,
    "extension": ".sha256"
  },
  "platforms": {
    "linux": ["x64", "arm64"],
    "darwin": ["x64", "arm64"]
  }
}
