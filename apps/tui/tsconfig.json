{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsxImportSource": "@opentui/react",
    "paths": {
      "@/*": ["src/*"],
      "@ralpher/shared": ["../../packages/shared/src/index.ts"],
      "@ralpher/shared/*": ["../../packages/shared/src/*"],
      "@ralpher/contracts": ["../../packages/contracts/src/index.ts"],
      "@ralpher/contracts/*": ["../../packages/contracts/src/*"],
      "@ralpher/client-sdk": ["../../packages/client-sdk/src/index.ts"],
      "@ralpher/client-sdk/*": ["../../packages/client-sdk/src/*"]
    }
  },
  "include": ["src/**/*"]
}
